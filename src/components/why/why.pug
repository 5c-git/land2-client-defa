include ../counter/counter

div.why
  div.why__header
    +counter({
      four: true,
    })


  div.why__main
    div.why__background
      img(src="./assets/images/why-background-1.png" alt="")
    div.why__list
      div.why__item
       span.why__item-title
        i.why__item-icon
          svg(width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg")
